<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\CodeIndexer.Core\CodeIndexer.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="TypeScriptAST" Version="1.0.2" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- TypeScriptAST targets .NET Framework; it has no native/P-Invoke surface so the .NET 8 compat shim is safe. -->
    <NoWarn>$(NoWarn);NU1701</NoWarn>
  </PropertyGroup>

</Project>
